{
  "manifest_version": 3,
  "name": "MeguProxy",
  "version": "1.2",
  "description": "Управление проксированием сайтов по правилам средствами SOCKS/HTTP, а также фильтрация от трекеров средствами списков | Автор: Ventor DIMITRUSH",
  "browser_specific_settings": {
    "gecko": {
      "id": "senkoproxy@cla.st",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "incognito": "spanning",
  "permissions": [
    "proxy",
    "storage",
    "tabs",
    "alarms",
    "webRequest",
    "webRequestBlocking"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "64": "icon.png"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "MeguProxy",
    "default_icon": {
      "64": "icon.png"
    }
  }
}
